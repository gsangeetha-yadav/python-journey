# Easy password checker with digit check

password = input("Enter password: ")

has_digit = False

# Check if password has a number
for ch in password:
    if ch.isdigit():
        has_digit = True

# Decide strength
if len(password) >= 8 and has_digit:
    print("Strength: STRONG")

elif len(password) >= 6:
    print("Strength: MEDIUM")

else:
    print("Strength: WEAK")
